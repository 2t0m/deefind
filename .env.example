# Deezer ARL Token (required for downloading)
# Get it from your browser cookies after logging into Deezer
DEEMIX_ARL=your_arl_token_here

# Navidrome Configuration (optional, for duplicate detection)
NAVIDROME_URL=http://host:4533
NAVIDROME_USER=admin
NAVIDROME_PASS=admin

# Download Directory (inside container)
DOWNLOAD_DIR=/downloads
